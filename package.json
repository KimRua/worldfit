{
  "name": "verifit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "db:up": "docker compose up -d mysql mailpit",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql mailpit",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "start:server": "node server/index.js"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@worldcoin/idkit": "^4.1.1",
    "@worldcoin/minikit-js": "^2.0.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mysql2": "^3.22.2",
    "nodemailer": "^8.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "viem": "^2.48.4"
  }
}
